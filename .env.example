# === Claude API（ニュース/SNSセンチメント分析用）===
# https://console.anthropic.com/ で取得
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# === auカブコム証券 kabuステーションAPI（ライブ発注用）===
# kabuステーションを起動し、API設定でパスワードを発行してください。
# 本番=18080 / 検証=18081
KABUS_API_PASSWORD=your_kabus_api_password
KABUS_BASE_URL=http://localhost:18080/kabusapi

# ライブ発注の安全スイッチ。実弾を出すには明示的に true にする必要があります。
# （デフォルト false = ペーパートレード）
AUTOTRADER_ENABLE_LIVE=false

# === J-Quants API（ヒストリカル日足の取得用 / GUI自動操作の代替）===
# https://jpx-jquants.com/ で登録。マイページのリフレッシュトークンを推奨。
# 取得: `autotrader fetch-data` でユニバースの日足を data/history へ保存。
JQUANTS_REFRESH_TOKEN=your_jquants_refresh_token
# あるいはメール/パスワードでも可（リフレッシュトークンを自動取得）
# JQUANTS_MAILADDRESS=you@example.com
# JQUANTS_PASSWORD=your_password

# === スマホ通知（完全自動運用の状況をスマホで受け取る）===
# Discord: サーバー設定 → 連携サービス → ウェブフック で取得
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxx/yyyyy
# Telegram: @BotFather でBot作成しトークン取得、chat_id は @userinfobot 等で確認
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=123456789
